# ============================================
# Transport MVP - Environment Variables
# ============================================

# App
APP_NAME=Transport MVP API
APP_VERSION=1.0.0
DEBUG=true

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://admin:password@localhost:5432/transport_mvp

# JWT Auth
JWT_SECRET_KEY=ganti-dengan-secret-key-yang-aman-minimal-32-karakter
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# Firebase
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# Pricing (Ojek)
BASE_FARE=5000
RATE_PER_KM=4000

# Matching
MATCHING_RADIUS_KM=3.0
ORDER_TIMEOUT_SECONDS=60

# OSRM
OSRM_BASE_URL=https://router.project-osrm.org

# CORS
CORS_ORIGINS=["http://localhost:3001","http://localhost:3002","http://localhost:3003","http://localhost:5173"]
